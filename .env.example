# Dimes API base URL. Defaults to the public sandbox if unset.
VITE_API_URL=https://api-sandbox.dimes.fi

# EVM chain id. 137 = Polygon mainnet, 80002 = Polygon Amoy (testnet).
VITE_CHAIN_ID=137

# Optional custom RPC URL for the chain above. Leave empty to use the
# default public RPC bundled with wagmi. Set this if you want to use your
# own Alchemy / Infura / QuickNode endpoint (recommended for reliability).
VITE_RPC_URL=

# WalletConnect Cloud project id. The repo ships a demo project id that
# works out of the box; get your own free id at
# https://cloud.walletconnect.com if you fork this for production use.
VITE_WALLETCONNECT_PROJECT_ID=

# ---------------------------------------------------------------------------
# DEMO-ONLY: optional partner API key for minting real JWTs directly from the
# browser via POST /v1/prediction-markets/tokens. If unset, the UI falls back
# to POST /demo-token which issues sandbox-only JWTs pinned to a fixed demo
# wallet.
#
# DO NOT SHIP A REAL API KEY IN A FRONTEND. In production, tokens must be
# minted by your backend with the API key kept server-side, and your frontend
# should receive the JWT from your backend. This field exists only so the
# demo can run end-to-end with a single command.
# ---------------------------------------------------------------------------
VITE_API_KEY=
